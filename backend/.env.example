# ── OpenAI ──
OPENAI_API_KEY=sk-your-key-here

# ── Embedding ──
# ASA_EMBEDDING_PROVIDER=openai     # "openai" | "local"
# ASA_EMBEDDING_MODEL=text-embedding-3-small
# ASA_EMBEDDING_DIMENSION=1536
# Local BGE example (requires requirements-local.txt):
# ASA_EMBEDDING_PROVIDER=local
# ASA_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# ASA_EMBEDDING_DIMENSION=512

# ── LLM ──
# Supported provider presets:
# openai | gemini | deepseek | qwen | kimi | mistral | zhipu | xai | openrouter | ollama | custom
# ASA_LLM_PROVIDER=openai
# ASA_LLM_MODEL=gpt-4o-mini
# Optional override for OpenAI-compatible providers:
# ASA_LLM_BASE_URL=
# Provider-specific keys (set the one you use):
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# MOONSHOT_API_KEY=
# MISTRAL_API_KEY=
# ZHIPU_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
# Or use a generic OpenAI-compatible key:
# ASA_LLM_API_KEY=
# ASA_OLLAMA_BASE_URL=http://localhost:11434/v1

# ── RAG ──
# ASA_CHUNK_SIZE=512
# ASA_CHUNK_OVERLAP=64
# ASA_TOP_K=5
# ASA_SIMILARITY_THRESHOLD=0.3
# ASA_HYBRID_SEARCH_ENABLED=true
# ASA_RETRIEVAL_CANDIDATE_MULTIPLIER=4
# ASA_RRF_K=60
# Reject weak vector-only fallbacks in hybrid mode (calibrate with your evaluation set)
# ASA_RETRIEVAL_CONFIDENCE_GATE_ENABLED=true
# ASA_VECTOR_ONLY_MIN_SCORE=0.46
# Split compound questions into focused retrieval subqueries before fusing results
# ASA_QUERY_DECOMPOSITION_ENABLED=true
# ASA_QUERY_DECOMPOSITION_MAX_SUBQUERIES=3
# Optional local cross-encoder reranking (adds model size and CPU latency)
# ASA_RERANKER_ENABLED=false
# ASA_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# ASA_RERANKER_TOP_N=12

# ── Server ──
# ASA_HOST=127.0.0.1
# ASA_PORT=8000
